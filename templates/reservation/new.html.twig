{% extends 'base.html.twig' %}

{% block title %}Réserver - {{ event.title }}{% endblock %}

{% block body %}
<section class="py-5" style="background: linear-gradient(180deg, #f8fafc 0%, white 100%); min-height: calc(100vh - 200px);">
    <div class="container">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4" data-aos="fade-up">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('home') }}">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('event_index') }}">Événements</a></li>
                <li class="breadcrumb-item"><a href="{{ path('event_show', {id: event.id}) }}">{{ event.title }}</a></li>
                <li class="breadcrumb-item active">Réserver</li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- Reservation Form -->
            <div class="col-lg-7" data-aos="fade-right">
                <div class="card card-static" style="border-top: 4px solid var(--primary);">
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                 style="width: 56px; height: 56px; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                                <i class="bi bi-ticket-perforated fs-4" style="color: var(--primary);"></i>
                            </div>
                            <div>
                                <h4 class="fw-700 mb-0">Réserver votre place</h4>
                                <p class="text-muted small mb-0">Remplissez vos informations ci-dessous</p>
                            </div>
                        </div>

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                            <div class="mb-4">
                                <label class="form-label">Nom complet <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-person text-muted"></i>
                                    </span>
                                    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Votre nom et prénom'}}) }}
                                </div>
                                {{ form_errors(form.name) }}
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Adresse email <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'vous@exemple.com'}}) }}
                                </div>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1"></i>Nous vous enverrons la confirmation à cette adresse.
                                </div>
                                {{ form_errors(form.email) }}
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Téléphone</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-telephone text-muted"></i>
                                    </span>
                                    {{ form_widget(form.phone, {'attr': {'class': 'form-control', 'placeholder': '+216 XX XXX XXX'}}) }}
                                </div>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1"></i>Optionnel — pour les mises à jour de l'événement.
                                </div>
                                {{ form_errors(form.phone) }}
                            </div>

                            <hr class="my-4">

                            <div class="d-grid gap-3">
                                <button type="submit" class="btn btn-primary btn-lg fw-600">
                                    <i class="bi bi-check-circle me-2"></i>Confirmer ma réservation
                                </button>
                                <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Annuler et revenir
                                </a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>

            <!-- Event Summary Card -->
            <div class="col-lg-5" data-aos="fade-left">
                <div class="card card-static sticky-top" style="top: 100px;">
                    <!-- Event Image -->
                    {% if event.image %}
                        <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" 
                             style="height: 180px; object-fit: cover; border-radius: 16px 16px 0 0;">
                    {% else %}
                        <div class="event-image-placeholder" style="height: 180px; border-radius: 16px 16px 0 0;">
                            <i class="bi bi-calendar-event"></i>
                        </div>
                    {% endif %}

                    <div class="card-body p-4">
                        <h5 class="fw-700 mb-3">
                            <i class="bi bi-calendar-event me-2" style="color: var(--primary);"></i>
                            Récapitulatif
                        </h5>

                        <div class="bg-light rounded-lg p-3 mb-3">
                            <h6 class="fw-700 mb-3">{{ event.title }}</h6>
                            
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-calendar3 me-2" style="color: var(--primary); width: 20px;"></i>
                                <span>{{ event.date|date('l d F Y') }}</span>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-clock me-2" style="color: var(--primary); width: 20px;"></i>
                                <span>{{ event.date|date('H:i') }}</span>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-geo-alt me-2" style="color: var(--primary); width: 20px;"></i>
                                <span>{{ event.location }}</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-people me-2" style="color: var(--primary); width: 20px;"></i>
                                <span class="text-success fw-600">{{ event.availableSeats }} places restantes</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center p-3 rounded-lg" 
                             style="background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                            <span class="fw-600" style="color: var(--primary);">Prix total</span>
                            <span class="fw-800 fs-4" style="color: var(--primary);">Gratuit</span>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 px-4 pb-4">
                        <div class="d-flex align-items-start gap-2 p-3 bg-success-subtle rounded-lg">
                            <i class="bi bi-shield-check text-success mt-1"></i>
                            <div>
                                <div class="fw-600 text-success small">Réservation gratuite</div>
                                <div class="text-muted small">Aucun paiement requis pour cet événement.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
