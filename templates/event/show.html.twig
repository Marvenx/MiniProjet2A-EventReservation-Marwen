{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - EventHub{% endblock %}

{% block body %}
<!-- Hero Image Section -->
<section class="position-relative" style="height: 350px; overflow: hidden;">
    {% if event.image %}
        <img src="{{ event.image }}" class="w-100 h-100" alt="{{ event.title }}" style="object-fit: cover;">
    {% else %}
        <div class="w-100 h-100 hero-gradient d-flex align-items-center justify-content-center">
            <i class="bi bi-calendar-event text-white" style="font-size: 6rem; opacity: 0.3;"></i>
        </div>
    {% endif %}
    <!-- Gradient Overlay -->
    <div class="position-absolute bottom-0 start-0 end-0 p-4 p-lg-5"
         style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);">
        <div class="container">
            <nav aria-label="breadcrumb" class="mb-3" data-aos="fade-up">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('home') }}" class="text-white-50">Accueil</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('event_index') }}" class="text-white-50">Événements</a></li>
                    <li class="breadcrumb-item active text-white">{{ event.title }}</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-800 text-white mb-2" data-aos="fade-up" data-aos-delay="100">{{ event.title }}</h1>
            <div class="d-flex flex-wrap gap-2" data-aos="fade-up" data-aos-delay="200">
                {% if event.isSoldOut %}
                    <span class="badge bg-danger fs-6 px-3 py-2">
                        <i class="bi bi-x-circle me-1"></i>Complet
                    </span>
                {% else %}
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i>Places disponibles
                    </span>
                {% endif %}
                <span class="badge fs-6 px-3 py-2" style="background: rgba(255,255,255,0.2);">
                    <i class="bi bi-geo-alt me-1"></i>{{ event.location }}
                </span>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Event Details -->
            <div class="col-lg-8" data-aos="fade-right">
                <!-- Info Cards Row -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card card-static h-100 text-center p-3">
                            <i class="bi bi-calendar3 fs-3 mb-2" style="color: var(--primary);"></i>
                            <div class="fw-700">{{ event.date|date('d') }}</div>
                            <div class="text-muted small text-uppercase">{{ event.date|date('M Y') }}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card card-static h-100 text-center p-3">
                            <i class="bi bi-clock fs-3 mb-2" style="color: var(--accent);"></i>
                            <div class="fw-700">{{ event.date|date('H:i') }}</div>
                            <div class="text-muted small">Heure</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card card-static h-100 text-center p-3">
                            <i class="bi bi-geo-alt fs-3 mb-2" style="color: #10b981;"></i>
                            <div class="fw-700 text-truncate">{{ event.location }}</div>
                            <div class="text-muted small">Lieu</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card card-static h-100 text-center p-3">
                            <i class="bi bi-people fs-3 mb-2 text-{{ event.availableSeats > 10 ? 'success' : (event.availableSeats > 0 ? 'warning' : 'danger') }}"></i>
                            <div class="fw-700">{{ event.availableSeats }} / {{ event.seats }}</div>
                            <div class="text-muted small">Places</div>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                <div class="card card-static">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-700 mb-0">
                            <i class="bi bi-info-circle me-2" style="color: var(--primary);"></i>
                            À propos de cet événement
                        </h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <p class="mb-0" style="white-space: pre-line; line-height: 1.8;">{{ event.description }}</p>
                    </div>
                </div>
            </div>

            <!-- Reservation Card -->
            <div class="col-lg-4" data-aos="fade-left">
                <div class="card card-static sticky-top" style="top: 100px; border-top: 4px solid var(--primary);">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                                 style="width: 64px; height: 64px; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                                <i class="bi bi-ticket-perforated fs-3" style="color: var(--primary);"></i>
                            </div>
                            <h5 class="fw-700 mb-1">Réserver une place</h5>
                            <p class="text-muted small mb-0">Inscription gratuite</p>
                        </div>

                        <!-- Event Summary -->
                        <div class="bg-light rounded-lg p-3 mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Événement</span>
                                <span class="fw-600">{{ event.title|slice(0, 20) }}{% if event.title|length > 20 %}...{% endif %}</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Date</span>
                                <span class="fw-600">{{ event.date|date('d/m/Y') }}</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Heure</span>
                                <span class="fw-600">{{ event.date|date('H:i') }}</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Prix</span>
                                <span class="fw-700 text-success">Gratuit</span>
                            </div>
                        </div>

                        <!-- Seats Status -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted small">Places restantes</span>
                                <span class="fw-700 text-{{ event.availableSeats > 10 ? 'success' : (event.availableSeats > 0 ? 'warning' : 'danger') }}">
                                    {{ event.availableSeats }} / {{ event.seats }}
                                </span>
                            </div>
                            <div class="progress" style="height: 8px; border-radius: 4px;">
                                {% set percentage = ((event.seats - event.availableSeats) / event.seats) * 100 %}
                                <div class="progress-bar bg-{{ percentage > 90 ? 'danger' : (percentage > 70 ? 'warning' : 'primary') }}" 
                                     style="width: {{ percentage }}%; border-radius: 4px;"></div>
                            </div>
                        </div>

                        <!-- CTA Button -->
                        {% if event.isSoldOut %}
                            <button class="btn btn-secondary btn-lg w-100 fw-600" disabled>
                                <i class="bi bi-x-circle me-2"></i>Complet
                            </button>
                            <p class="text-center text-muted small mt-3 mb-0">
                                <i class="bi bi-bell me-1"></i>Revenez plus tard pour d'autres événements
                            </p>
                        {% else %}
                            <a href="{{ path('reservation_new', {id: event.id}) }}" class="btn btn-primary btn-lg w-100 fw-600">
                                <i class="bi bi-ticket-perforated me-2"></i>Réserver maintenant
                            </a>
                            <p class="text-center text-muted small mt-3 mb-0">
                                <i class="bi bi-shield-check me-1"></i>Réservation sécurisée et gratuite
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Back Button -->
        <div class="mt-5" data-aos="fade-up">
            <a href="{{ path('event_index') }}" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i>Retour aux événements
            </a>
        </div>
    </div>
</section>
{% endblock %}
