{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - Event Reservation{% endblock %}

{% block body %}
<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
            <li class="breadcrumb-item"><a href="{{ path('event_index') }}">Events</a></li>
            <li class="breadcrumb-item active">{{ event.title }}</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Event Image -->
        <div class="col-lg-6 mb-4">
            <div class="event-image-placeholder rounded" style="height: 350px; font-size: 5rem;">
                <i class="bi bi-calendar-event"></i>
            </div>
        </div>

        <!-- Event Details -->
        <div class="col-lg-6">
            <h1 class="mb-3">{{ event.title }}</h1>
            
            <!-- Status Badge -->
            <div class="mb-3">
                {% if event.isSoldOut %}
                    <span class="badge bg-danger fs-6">
                        <i class="bi bi-x-circle"></i> Sold Out
                    </span>
                {% else %}
                    <span class="badge bg-success fs-6">
                        <i class="bi bi-check-circle"></i> Available
                    </span>
                {% endif %}
            </div>

            <!-- Event Info Cards -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <h6 class="text-muted mb-1">
                                <i class="bi bi-calendar3 text-primary"></i> Date
                            </h6>
                            <p class="mb-0 fw-bold">{{ event.date|date('l, F j, Y') }}</p>
                        </div>
                        <div class="col-6 mb-3">
                            <h6 class="text-muted mb-1">
                                <i class="bi bi-clock text-primary"></i> Time
                            </h6>
                            <p class="mb-0 fw-bold">{{ event.date|date('g:i A') }}</p>
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted mb-1">
                                <i class="bi bi-geo-alt text-primary"></i> Location
                            </h6>
                            <p class="mb-0 fw-bold">{{ event.location }}</p>
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted mb-1">
                                <i class="bi bi-people text-primary"></i> Seats
                            </h6>
                            <p class="mb-0">
                                <span class="fw-bold text-{{ event.availableSeats > 10 ? 'success' : (event.availableSeats > 0 ? 'warning' : 'danger') }}">
                                    {{ event.availableSeats }}
                                </span>
                                <span class="text-muted">/ {{ event.seats }} available</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reserve Button - Route will be added in Phase 6 -->
            {% if event.isSoldOut %}
                <button class="btn btn-secondary btn-lg w-100" disabled>
                    <i class="bi bi-x-circle"></i> Sold Out - No tickets available
                </button>
            {% else %}
                <button class="btn btn-success btn-lg w-100" disabled>
                    <i class="bi bi-ticket-perforated"></i> Reserve Your Spot (Coming Soon)
                </button>
            {% endif %}
        </div>
    </div>

    <!-- Description Section -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> About This Event</h5>
                </div>
                <div class="card-body">
                    <p class="lead mb-0" style="white-space: pre-line;">{{ event.description }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
        <a href="{{ path('event_index') }}" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back to All Events
        </a>
    </div>
</div>
{% endblock %}
