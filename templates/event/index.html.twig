{% extends 'base.html.twig' %}

{% block title %}All Events - Event Reservation{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calendar3"></i> All Events</h1>
        <span class="badge bg-primary fs-6">{{ events|length }} events</span>
    </div>

    {% if events is empty %}
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No events available at the moment.
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for event in events %}
                <div class="col">
                    <div class="card h-100 event-card">
                        {% if event.image %}
                            <img src="{{ event.image }}" class="card-img-top event-image" alt="{{ event.title }}">
                        {% else %}
                            <div class="event-image-placeholder">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ event.title }}</h5>
                            <p class="card-text">
                                {{ event.description|length > 100 ? event.description|slice(0, 100) ~ '...' : event.description }}
                            </p>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <i class="bi bi-calendar3 text-primary"></i>
                                {{ event.date|date('l, F j, Y') }}
                            </li>
                            <li class="list-group-item">
                                <i class="bi bi-clock text-primary"></i>
                                {{ event.date|date('g:i A') }}
                            </li>
                            <li class="list-group-item">
                                <i class="bi bi-geo-alt text-primary"></i>
                                {{ event.location }}
                            </li>
                            <li class="list-group-item">
                                <i class="bi bi-people text-primary"></i>
                                {% if event.isSoldOut %}
                                    <span class="text-danger fw-bold">Sold Out</span>
                                {% else %}
                                    <span class="text-success">{{ event.availableSeats }} / {{ event.seats }} seats available</span>
                                {% endif %}
                            </li>
                        </ul>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
