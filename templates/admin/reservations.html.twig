{% extends 'base.html.twig' %}

{% block title %}Réservations - Admin EventHub{% endblock %}

{% block stylesheets %}
<style>
    .admin-layout { display: flex; min-height: calc(100vh - 76px); }
    .admin-content { flex: 1; padding: 2rem; background: var(--surface); }
</style>
{% endblock %}

{% block body %}
<div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar d-none d-lg-block" style="width: 260px;">
        <div class="p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width: 48px; height: 48px; background: var(--primary);">
                    <i class="bi bi-speedometer2 text-white fs-5"></i>
                </div>
                <div>
                    <div class="text-white fw-700">Admin Panel</div>
                    <div class="text-muted small">EventHub</div>
                </div>
            </div>
        </div>
        
        <nav class="nav flex-column">
            <a href="{{ path('admin_dashboard') }}" class="nav-link">
                <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard
            </a>
            <a href="{{ path('admin_event_new') }}" class="nav-link">
                <i class="bi bi-plus-circle me-2"></i>Nouvel Événement
            </a>
            <a href="{{ path('admin_reservations') }}" class="nav-link active">
                <i class="bi bi-ticket-perforated me-2"></i>Réservations
            </a>
            <a href="{{ path('app_admin_register') }}" class="nav-link">
                <i class="bi bi-person-plus me-2"></i>Créer Admin
            </a>
            <hr class="my-3 mx-3" style="border-color: #334155;">
            <a href="{{ path('home') }}" class="nav-link">
                <i class="bi bi-house me-2"></i>Retour au site
            </a>
            <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-up">
            <div>
                <h1 class="fw-800 mb-1">
                    <i class="bi bi-ticket-perforated me-2" style="color: var(--primary);"></i>
                    Réservations
                </h1>
                <p class="text-muted mb-0">Toutes les réservations des événements</p>
            </div>
            <span class="badge bg-success fs-6 px-3 py-2">
                <i class="bi bi-check-circle me-1"></i>{{ reservations|length }} total
            </span>
        </div>

        <!-- Reservations Table -->
        <div class="card card-static" data-aos="fade-up" data-aos-delay="100">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Événement</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Date de réservation</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reservation in reservations %}
                            <tr>
                                <td class="ps-4 text-muted">{{ reservation.id }}</td>
                                <td>
                                    <a href="{{ path('event_show', {id: reservation.event.id}) }}" 
                                       class="fw-600 text-decoration-none d-flex align-items-center gap-2">
                                        <div class="rounded d-flex align-items-center justify-content-center"
                                             style="width: 32px; height: 32px; background: var(--primary);">
                                            <i class="bi bi-calendar-event text-white small"></i>
                                        </div>
                                        {{ reservation.event.title }}
                                    </a>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width: 32px; height: 32px; background: #f1f5f9;">
                                            <i class="bi bi-person text-muted small"></i>
                                        </div>
                                        <span class="fw-500">{{ reservation.name }}</span>
                                    </div>
                                </td>
                                <td>
                                    <a href="mailto:{{ reservation.email }}" class="text-decoration-none">
                                        <i class="bi bi-envelope me-1 text-muted"></i>
                                        {{ reservation.email }}
                                    </a>
                                </td>
                                <td>
                                    {% if reservation.phone %}
                                        <i class="bi bi-telephone me-1 text-muted"></i>
                                        {{ reservation.phone }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="bi bi-clock me-1"></i>
                                        {{ reservation.createdAt|date('d/m/Y H:i') }}
                                    </span>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                                         style="width: 64px; height: 64px; background: #f1f5f9;">
                                        <i class="bi bi-ticket-perforated fs-3 text-muted"></i>
                                    </div>
                                    <p class="text-muted mb-0">Aucune réservation pour le moment</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}
