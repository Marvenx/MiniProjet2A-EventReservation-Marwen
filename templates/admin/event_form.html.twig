{% extends 'base.html.twig' %}

{% block title %}{{ action }} Événement - Admin EventHub{% endblock %}

{% block stylesheets %}
<style>
    .admin-layout { display: flex; min-height: calc(100vh - 76px); }
    .admin-content { flex: 1; padding: 2rem; background: var(--surface); }
</style>
{% endblock %}

{% block body %}
<div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar d-none d-lg-block" style="width: 260px;">
        <div class="p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width: 48px; height: 48px; background: var(--primary);">
                    <i class="bi bi-speedometer2 text-white fs-5"></i>
                </div>
                <div>
                    <div class="text-white fw-700">Admin Panel</div>
                    <div class="text-muted small">EventHub</div>
                </div>
            </div>
        </div>
        
        <nav class="nav flex-column">
            <a href="{{ path('admin_dashboard') }}" class="nav-link">
                <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard
            </a>
            <a href="{{ path('admin_event_new') }}" class="nav-link {{ action == 'Créer' ? 'active' : '' }}">
                <i class="bi bi-plus-circle me-2"></i>Nouvel Événement
            </a>
            <a href="{{ path('admin_reservations') }}" class="nav-link">
                <i class="bi bi-ticket-perforated me-2"></i>Réservations
            </a>
            <a href="{{ path('app_register') }}" class="nav-link">
                <i class="bi bi-person-plus me-2"></i>Créer Admin
            </a>
            <hr class="my-3 mx-3" style="border-color: #334155;">
            <a href="{{ path('home') }}" class="nav-link">
                <i class="bi bi-house me-2"></i>Retour au site
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
        <div class="container-fluid" style="max-width: 800px;">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4" data-aos="fade-up">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Admin</a></li>
                    <li class="breadcrumb-item active">{{ action }} Événement</li>
                </ol>
            </nav>

            <div class="card card-static" style="border-top: 4px solid var(--primary);" data-aos="fade-up" data-aos-delay="100">
                <div class="card-body p-4 p-lg-5">
                    <!-- Header -->
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                             style="width: 56px; height: 56px; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                            <i class="bi bi-{{ action == 'Créer' ? 'plus-circle' : 'pencil' }} fs-4" style="color: var(--primary);"></i>
                        </div>
                        <div>
                            <h4 class="fw-700 mb-0">{{ action }} un événement</h4>
                            <p class="text-muted small mb-0">
                                {{ action == 'Créer' ? 'Ajoutez un nouvel événement au système' : 'Modifiez les informations de l\'événement' }}
                            </p>
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-4">
                            <label class="form-label">Titre de l'événement <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-type text-muted"></i>
                                </span>
                                {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Conférence Tech 2026'}}) }}
                            </div>
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Description <span class="text-danger">*</span></label>
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 5, 'placeholder': 'Décrivez votre événement en détail...'}}) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">Date et heure <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-calendar3 text-muted"></i>
                                    </span>
                                    {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                                </div>
                                {{ form_errors(form.date) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nombre de places <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-people text-muted"></i>
                                    </span>
                                    {{ form_widget(form.seats, {'attr': {'class': 'form-control', 'placeholder': '100'}}) }}
                                </div>
                                {{ form_errors(form.seats) }}
                            </div>
                        </div>

                        <div class="mb-4 mt-4">
                            <label class="form-label">Lieu <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-geo-alt text-muted"></i>
                                </span>
                                {{ form_widget(form.location, {'attr': {'class': 'form-control', 'placeholder': 'Ex: ISSAT Sousse, Salle 101'}}) }}
                            </div>
                            {{ form_errors(form.location) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label">URL de l'image</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-image text-muted"></i>
                                </span>
                                {{ form_widget(form.image, {'attr': {'class': 'form-control', 'placeholder': 'https://exemple.com/image.jpg'}}) }}
                            </div>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>Laissez vide pour utiliser l'image par défaut
                            </div>
                            {{ form_errors(form.image) }}
                        </div>

                        <hr class="my-4">

                        <div class="d-flex flex-wrap gap-3">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-2"></i>
                                {{ action == 'Créer' ? 'Créer l\'événement' : 'Enregistrer les modifications' }}
                            </button>
                            <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
