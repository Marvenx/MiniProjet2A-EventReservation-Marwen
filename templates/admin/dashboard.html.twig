{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - EventHub{% endblock %}

{% block stylesheets %}
<style>
    .admin-layout { display: flex; min-height: calc(100vh - 76px); }
    .admin-content { flex: 1; padding: 2rem; background: var(--surface); }
    .stat-card { border-radius: var(--radius); padding: 1.5rem; color: white; }
    .stat-card .stat-icon { font-size: 2.5rem; opacity: 0.3; }
    .stat-card .stat-value { font-size: 2.5rem; font-weight: 800; }
    .btn-fab {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(99,102,241,0.4);
        z-index: 100;
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar d-none d-lg-block" style="width: 260px;">
        <div class="p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                     style="width: 48px; height: 48px; background: var(--primary);">
                    <i class="bi bi-speedometer2 text-white fs-5"></i>
                </div>
                <div>
                    <div class="text-white fw-700">Admin Panel</div>
                    <div class="text-muted small">EventHub</div>
                </div>
            </div>
        </div>
        
        <nav class="nav flex-column">
            <a href="{{ path('admin_dashboard') }}" class="nav-link active">
                <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard
            </a>
            <a href="{{ path('admin_event_new') }}" class="nav-link">
                <i class="bi bi-plus-circle me-2"></i>Nouvel Événement
            </a>
            <a href="{{ path('admin_reservations') }}" class="nav-link">
                <i class="bi bi-ticket-perforated me-2"></i>Réservations
            </a>
            <a href="{{ path('app_admin_register') }}" class="nav-link">
                <i class="bi bi-person-plus me-2"></i>Créer Admin
            </a>
            <hr class="my-3 mx-3" style="border-color: #334155;">
            <a href="{{ path('home') }}" class="nav-link">
                <i class="bi bi-house me-2"></i>Retour au site
            </a>
            <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-up">
            <div>
                <h1 class="fw-800 mb-1">Dashboard</h1>
                <p class="text-muted mb-0">Bienvenue, {{ app.user.email|split('@')[0] }} 👋</p>
            </div>
            <a href="{{ path('admin_event_new') }}" class="btn btn-primary d-none d-md-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i>Nouvel événement
            </a>
        </div>

        <!-- Stats Cards -->
        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-xl-3" data-aos="fade-up">
                <div class="stat-card" style="background: linear-gradient(135deg, var(--primary) 0%, #8b5cf6 100%);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small fw-500 mb-1">Total Événements</div>
                            <div class="stat-value">{{ events|length }}</div>
                        </div>
                        <i class="bi bi-calendar-event stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small fw-500 mb-1">Réservations</div>
                            <div class="stat-value">{{ totalReservations }}</div>
                        </div>
                        <i class="bi bi-ticket-perforated stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-card" style="background: linear-gradient(135deg, var(--accent) 0%, #d97706 100%);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small fw-500 mb-1">Ce mois</div>
                            <div class="stat-value">{{ events|filter(e => e.date > date())|length }}</div>
                        </div>
                        <i class="bi bi-calendar-check stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-card" style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-white-50 small fw-500 mb-1">Places Total</div>
                            <div class="stat-value">{% set totalSeats = 0 %}{% for e in events %}{% set totalSeats = totalSeats + e.seats %}{% endfor %}{{ totalSeats }}</div>
                        </div>
                        <i class="bi bi-people stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Events Table -->
        <div class="card card-static" data-aos="fade-up" data-aos-delay="400">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center py-3">
                <h5 class="fw-700 mb-0">
                    <i class="bi bi-calendar-event me-2" style="color: var(--primary);"></i>
                    Tous les événements
                </h5>
                <span class="badge bg-primary">{{ events|length }}</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 50px;"></th>
                            <th>Événement</th>
                            <th>Date</th>
                            <th>Lieu</th>
                            <th class="text-center">Places</th>
                            <th class="text-center">Réservations</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td class="ps-4">
                                    {% if event.image %}
                                        <img src="{{ event.image }}" alt="" class="rounded" 
                                             style="width: 40px; height: 40px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded d-flex align-items-center justify-content-center"
                                             style="width: 40px; height: 40px; background: var(--primary);">
                                            <i class="bi bi-calendar-event text-white small"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('event_show', {id: event.id}) }}" class="fw-600 text-decoration-none">
                                        {{ event.title }}
                                    </a>
                                </td>
                                <td class="text-muted">{{ event.date|date('d/m/Y H:i') }}</td>
                                <td>
                                    <span class="badge" style="background: #ede9fe; color: var(--primary);">
                                        {{ event.location }}
                                    </span>
                                </td>
                                <td class="text-center">{{ event.seats }}</td>
                                <td class="text-center">
                                    <span class="badge bg-{{ event.isSoldOut ? 'danger' : 'success' }}">
                                        {{ event.reservations|length }} / {{ event.seats }}
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_event_edit', {id: event.id}) }}" 
                                           class="btn btn-outline-primary" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" 
                                                title="Supprimer"
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteModal{{ event.id }}">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    <!-- Delete Modal -->
                                    <div class="modal fade" id="deleteModal{{ event.id }}" tabindex="-1">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow">
                                                <div class="modal-header border-0">
                                                    <h5 class="modal-title fw-700">
                                                        <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                                                        Confirmer la suppression
                                                    </h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Voulez-vous vraiment supprimer <strong>{{ event.title }}</strong> ?</p>
                                                    {% if event.reservations|length > 0 %}
                                                        <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-0">
                                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                                            <span>Cet événement a <strong>{{ event.reservations|length }}</strong> réservation(s) !</span>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                                <div class="modal-footer border-0">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                                        Annuler
                                                    </button>
                                                    <form action="{{ path('admin_event_delete', {id: event.id}) }}" method="post" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                                        <button type="submit" class="btn btn-danger">
                                                            <i class="bi bi-trash me-1"></i>Supprimer
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                                         style="width: 64px; height: 64px; background: #f1f5f9;">
                                        <i class="bi bi-calendar-x fs-3 text-muted"></i>
                                    </div>
                                    <p class="text-muted mb-2">Aucun événement pour le moment</p>
                                    <a href="{{ path('admin_event_new') }}" class="btn btn-primary btn-sm">
                                        <i class="bi bi-plus-lg me-1"></i>Créer un événement
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- FAB Button (Mobile) -->
<a href="{{ path('admin_event_new') }}" class="btn btn-primary btn-fab d-lg-none">
    <i class="bi bi-plus-lg fs-4"></i>
</a>
{% endblock %}
