{% extends 'base.html.twig' %}

{% block title %}Créer un compte - EventHub{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center py-5"
     style="background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card card-static p-4 p-md-5" style="border-top: 4px solid var(--primary);" data-aos="fade-up">

                    <!-- Header -->
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                             style="width: 64px; height: 64px; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                            <i class="bi bi-person-fill-add fs-3" style="color: var(--primary);"></i>
                        </div>
                        <h4 class="fw-800 mb-1">Créer un compte</h4>
                        <p class="text-muted small mb-0">Rejoignez EventHub et réservez des événements</p>
                    </div>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="mb-3">
                            <label class="form-label fw-600">Adresse email</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'vous@exemple.com', 'autofocus': 'autofocus'}}) }}
                            </div>
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-600">Mot de passe</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Minimum 6 caractères'}}) }}
                            </div>
                            {{ form_errors(form.plainPassword.first) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-600">Confirmer le mot de passe</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock-fill text-muted"></i>
                                </span>
                                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Répétez le mot de passe'}}) }}
                            </div>
                            {{ form_errors(form.plainPassword.second) }}
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-600 py-2 mb-3">
                            <i class="bi bi-check-circle me-2"></i>Créer mon compte
                        </button>
                    {{ form_end(form) }}

                    <!-- Back to Login -->
                    <div class="text-center pt-3 border-top">
                        <p class="text-muted small mb-2">Vous avez déjà un compte ?</p>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary btn-sm rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                        </a>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="text-center mt-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="d-inline-block bg-white rounded-lg px-4 py-3 shadow-sm">
                        <p class="small text-muted mb-0">
                            <i class="bi bi-shield-check me-1"></i>
                            Vos données sont sécurisées
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
