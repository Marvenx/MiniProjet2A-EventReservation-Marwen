{% extends 'base.html.twig' %}

{% block title %}Connexion - EventHub{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/passkey.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const togglePasswordBtn = document.getElementById('togglePasswordAuth');
            const passwordSection = document.getElementById('passwordSection');
            const passkeyLoginBtn = document.getElementById('passkeyLoginBtn');
            const passwordInput = document.getElementById('inputPassword');

            if (togglePasswordBtn) {
                togglePasswordBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    passwordSection.classList.toggle('d-none');
                    if (passwordSection.classList.contains('d-none')) {
                        togglePasswordBtn.innerHTML = '<i class="bi bi-key me-2"></i>Utiliser un mot de passe';
                    } else {
                        togglePasswordBtn.innerHTML = '<i class="bi bi-key me-2"></i>Masquer le mot de passe';
                        passwordInput.focus();
                    }
                });
            }
        });
    </script>
{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center py-5"
     style="background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card card-static p-4 p-md-5" style="border-top: 4px solid var(--primary);" data-aos="fade-up">

                    <!-- Header -->
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                             style="width: 64px; height: 64px; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);">
                            <i class="bi bi-shield-lock-fill fs-3" style="color: var(--primary);"></i>
                        </div>
                        <h4 class="fw-800 mb-1">Connexion</h4>
                        <p class="text-muted small mb-0">Accédez à votre compte EventHub</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                        </div>
                    {% endif %}

                    <!-- Login Form -->
                    <form method="post">
                        <!-- Email Field (Always Visible) -->
                        <div class="mb-4">
                            <label for="inputEmail" class="form-label fw-600">Adresse email</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <input type="email"
                                       name="_username"
                                       id="inputEmail"
                                       class="form-control"
                                       value="{{ last_username }}"
                                       placeholder="vous@exemple.com"
                                       required
                                       autofocus>
                            </div>
                        </div>

                        <!-- Passkey Option -->
                        <button id="passkeyLoginBtn"
                                type="button"
                                class="btn w-100 mb-3 fw-600 d-flex align-items-center justify-content-center gap-2"
                                style="background: #1e293b; color: white; border-radius: 10px; padding: 0.85rem;">
                            <i class="bi bi-fingerprint fs-5"></i>
                            <span>Se connecter avec Passkey</span>
                        </button>

                        <!-- Password Option Toggle -->
                        <button id="togglePasswordAuth"
                                type="button"
                                class="btn btn-outline-secondary w-100 mb-3 fw-600"
                                style="border-radius: 10px; padding: 0.7rem;">
                            <i class="bi bi-key me-2"></i>Utiliser un mot de passe
                        </button>

                        <!-- Password Section (Hidden by default) -->
                        <div id="passwordSection" class="d-none">
                            <div class="mb-4">
                                <label for="inputPassword" class="form-label fw-600">Mot de passe</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="password"
                                           name="_password"
                                           id="inputPassword"
                                           class="form-control"
                                           placeholder="••••••••">
                                </div>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button type="submit" class="btn btn-primary w-100 fw-600 py-2">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                            </button>
                        </div>
                    </form>

                    <!-- Signup Link -->
                    <div class="text-center pt-3 border-top">
                        <p class="text-muted small mb-2">Pas encore de compte ?</p>
                        <a href="{{ path('app_register') }}" class="btn btn-outline-primary btn-sm rounded-pill px-4">
                            <i class="bi bi-person-fill-add me-1"></i>Créer un compte
                        </a>
                    </div>
                </div>

                <!-- Demo Accounts Info -->
                <div class="text-center mt-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="d-inline-block bg-white rounded-lg px-4 py-3 shadow-sm">
                        <p class="small text-muted mb-1"><i class="bi bi-info-circle me-1"></i>Comptes de démonstration</p>
                        <div class="small">
                            <code>user@example.com</code> / <code>user123</code>
                            <br>
                            <code>admin@example.com</code> / <code>admin123</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
