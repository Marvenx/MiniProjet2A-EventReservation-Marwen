###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-this-secret-in-production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
## PostgreSQL - Local Development
DATABASE_URL="postgresql://postgres:your-password@127.0.0.1:5432/event_reservation?serverVersion=15&charset=utf8"

## PostgreSQL - Docker Environment (uncomment when using Docker)
# DATABASE_URL="postgresql://postgres:your-password@postgres:5432/event_reservation?serverVersion=15&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
## Gmail SMTP Example (configure with your credentials)
# MAILER_DSN=gmail://your-email@gmail.com:your-app-password@default

## SendGrid Example (alternative)
# MAILER_DSN=sendgrid+smtp://apikey:your-sendgrid-api-key@default

## Null transport - disables email sending (development only)
# MAILER_DSN=null://null@default
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
## JWT Keys - Location where the private and public keys are stored
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

## JWT Passphrase - Used to decrypt the private key
## IMPORTANT: Change this in production!
JWT_PASSPHRASE=your-secret-passphrase-change-in-production
###< lexik/jwt-authentication-bundle ###

###> Application URLs ###
## Default URI for the application
DEFAULT_URI=http://localhost:8000

## APP_DOMAIN - Required for WebAuthn/Passkey verification
## For localhost: use 'localhost'
## For production: use your actual domain (e.g., 'example.com')
APP_DOMAIN=localhost
###< Application URLs ###

###> Docker Specific (if using Docker deployment) ###
## When using Docker Compose, uncomment and adjust these values:
# APP_DOMAIN=localhost
# DATABASE_URL=postgresql://postgres:your-password@postgres:5432/event_reservation?serverVersion=15&charset=utf8
###< Docker Specific ###
